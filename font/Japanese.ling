ฟังก์ชัน จำนวนอักขระ_Japanese() { คืน 5 }
ฟังก์ชัน กว้าง_Japanese() { คืน [1.000,1.000,1.000,1.000,1.000] }
ฟังก์ชัน วาดอักขระ_Japanese(i, ox,oy,oz, rx,ry,rz, ux,uy,uz, s) {
    ถ้า i == 0 { อักขระ_Japanese_0(ox,oy,oz, rx,ry,rz, ux,uy,uz, s) }
    ถ้า i == 1 { อักขระ_Japanese_1(ox,oy,oz, rx,ry,rz, ux,uy,uz, s) }
    ถ้า i == 2 { อักขระ_Japanese_2(ox,oy,oz, rx,ry,rz, ux,uy,uz, s) }
    ถ้า i == 3 { อักขระ_Japanese_3(ox,oy,oz, rx,ry,rz, ux,uy,uz, s) }
    ถ้า i == 4 { อักขระ_Japanese_4(ox,oy,oz, rx,ry,rz, ux,uy,uz, s) }
}
