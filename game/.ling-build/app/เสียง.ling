# ────────────────────────────────────────────────────────────────────────────
# เสียง.ling — ชุดเสียงพื้นหลัง 4 มิติสำหรับแต่ละแดน
# ใช้ เสียงโทน(ดัชนี, x,y,z,w, ความถี่,แอมพลิจูด, อัตราLFO,ความลึกLFO)
# เรียกครั้งเดียวเมื่อเข้าแดน  เครื่องยนต์จะวนซ้ำโทนเสียงเอง
# ────────────────────────────────────────────────────────────────────────────

# ปิดเสียงไซน์ของตัวอักษร (ช่องเสียง 16..271) — เรียกเมื่อออกจากหน้าชื่อเรื่อง
ฟังก์ชัน ปิดเสียงอักษร() {
    ผูก v = 16
    ขณะที่ v < 272 {
        เสียงโทน(v, 0, 0, 0, 1.0, 220.0, 0.0, 0.0, 0.0)
        ผูก v = v + 1
    }
}

# หน้าชื่อเรื่อง: เสียงแวดล้อมลึกลับ
ฟังก์ชัน ตั้งเสียงชื่อ() {
    เสียงโทน(0,  0, 0, 0,  1.0,   55.0, 0.09, 0.18, 0.040)
    เสียงโทน(1,  0, 0, 0,  1.2,  110.0, 0.06, 0.28, 0.030)
    เสียงโทน(2,  0, 0, 0,  0.8,   82.5, 0.05, 0.22, 0.025)
    เสียงโทน(3,  0, 0, 0,  1.5,  440.0, 0.03, 0.80, 0.015)
    ระดับเสียง(0.5)
}

# แดน ๑ — ความว่างเปล่า
ฟังก์ชัน ตั้งเสียงความว่าง() {
    เสียงโทน(0,  0,       0,      0,    1.0,   55.0, 0.10, 0.20, 0.040)
    เสียงโทน(1,  8,       0,      4,    1.5,  110.0, 0.07, 0.30, 0.030)
    เสียงโทน(2,  0.0-8,   0,  0.0-4,   1.8,   82.5, 0.06, 0.25, 0.025)
    เสียงโทน(3,  0,       4,      8,    0.7,  165.0, 0.05, 0.50, 0.018)
    เสียงโทน(4,  4,   0.0-2,  0.0-6,   2.2,  220.0, 0.06, 0.40, 0.035)
    ระดับเสียง(0.55)
}

