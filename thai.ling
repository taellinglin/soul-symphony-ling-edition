// === HELPER FUNCTIONS ===

ฟังก์ชัน แสดง_ตำแหน่ง() {
  กำหนด ตำแหน่ง = สถานะ_ผู้เล่น.ตำแหน่ง_ปัจจุบัน
  กำหนด ข้อมูล = สถานที่[ตำแหน่ง]
  
  พิมพ์("")
  พิมพ์("========================================")
  พิมพ์("📍 " + ข้อมูล.ชื่อ)
  พิมพ์("========================================")
  พิมพ์(ข้อมูล.คำอธิบาย)
  พิมพ์("")
  
  // Show found items in this location
  ถ้า ตำแหน่ง == "ห้องดนตรี" และ สถานะ_ผู้เล่น.มี_ระนาด == เท็จ {
    พิมพ์("💡 คุณเห็นระนาด (Ranad) ซ่อนอยู่!")
  }
  
  ถ้า ตำแหน่ง == "สวน" และ สถานะ_ผู้เล่น.มี_โน้ตโด == เท็จ {
    พิมพ์("💡 คุณเห็นโน้ตโด (Do Note) เรืองแสงอยู่บนต้นไม้!")
  }
  
  ถ้า ตำแหน่ง == "ห้องโถงใหญ่" และ สถานะ_ผู้เล่น.มี_ขิม == เท็จ {
    พิมพ์("💡 คุณเห็นขิม (Khim) อยู่บนชั้น!")
  }
  
  ถ้า ตำแหน่ง == "ศาลา" และ สถานะ_ผู้เล่น.มี_โน้ตเร == เท็จ {
    พิมพ์("💡 คุณเห็นโน้ตเร (Re Note) ลอยอยู่!")
  }
  
  ถ้า ตำแหน่ง == "ห้องสมุด" และ สถานะ_ผู้เล่น.มี_ซอ == เท็จ {
    พิมพ์("💡 คุณเห็นซอ (Saw Duang) วางอยู่บนหนังสือ!")
  }
  
  ถ้า ตำแหน่ง == "น้ำตก" และ สถานะ_ผู้เล่น.มี_โน้ตมี == เท็จ {
    พิมพ์("💡 คุณเห็นโน้ตมี (Mi Note) ส่องแสงในน้ำ!")
  }
  
  ถ้า ตำแหน่ง == "ระเบียง" และ สถานะ_ผู้เล่น.มี_โน้ตฟา == เท็จ {
    พิมพ์("💡 คุณเห็นโน้ตฟา (Fa Note) ลอยอยู่บนท้องฟ้า!")
  }
  
  ถ้า ตำแหน่ง == "หอคอย" และ สถานะ_ผู้เล่น.มี_โน้ตซอล == เท็จ {
    พิมพ์("💡 คุณเห็นโน้ตซอล (Sol Note) อยู่บนยอดหอคอย!")
  }
  
  พิมพ์("")
  พิมพ์("🔄 ทางออก: " + ข้อมูล.ทางออก.เข้าร่วม(", "))
  พิมพ์("")
}

ฟังก์ชัน แสดง_สถานะ() {
  พิมพ์("")
  พิมพ์("📊 สถานะของคุณ:")
  พิมพ์("   คะแนน: " + สถานะ_ผู้เล่น.คะแนน)
  พิมพ์("   เครื่องดนตรี: " + (ถ้า สถานะ_ผู้เล่น.เครื่องดนตรี_ที่พบ.ความยาว > 0 แล้ว สถานะ_ผู้เล่น.เครื่องดนตรี_ที่พบ.เข้าร่วม(", ") มิฉะนั้น "ยังไม่พบ"))
  พิมพ์("   โน้ต: " + (ถ้า สถานะ_ผู้เล่น.โน้ต_ที่พบ.ความยาว > 0 แล้ว สถานะ_ผู้เล่น.โน้ต_ที่พบ.เข้าร่วม(", ") มิฉะนั้น "ยังไม่พบ"))
  พิมพ์("   บทเรียน: " + สถานะ_ผู้เล่น.บทเรียน_ที่เรียน.ความยาว + " บทเรียน")
  พิมพ์("")
}

ฟังก์ชัน จัดการ_คำสั่ง(คำสั่ง) {
  // Movement
  ถ้า คำสั่ง == "ไป" {
    รับ ปลายทาง
    พิมพ์("➡️ ไปที่ไหน?")
    รอ
    ปลายทาง = อ่าน()
    
    กำหนด สถานที่ปัจจุบัน = สถานะ_ผู้เล่น.ตำแหน่ง_ปัจจุบัน
    กำหนด ทางออก = สถานที่[สถานที่ปัจจุบัน].ทางออก
    
    ถ้า ทางออก.มี(ปลายทาง) {
      สถานะ_ผู้เล่น.ตำแหน่ง_ปัจจุบัน = ปลายทาง
      พิมพ์("🚶 คุณเดินไปที่ " + ปลายทาง)
      แสดง_ตำแหน่ง()
    } มิฉะนั้น {
      พิมพ์("❌ ไม่มีทางไป " + ปลายทาง + " จากที่นี่")
    }
    คืน
  }
  
  // Look around
  ถ้า คำสั่ง == "ดู" หรือ คำสั่ง == "มอง" {
    แสดง_ตำแหน่ง()
    คืน
  }
  
  // Status
  ถ้า คำสั่ง == "สถานะ" หรือ คำสั่ง == "check" {
    แสดง_สถานะ()
    คืน
  }
  
  // Help
  ถ้า คำสั่ง == "ช่วย" หรือ คำสั่ง == "help" {
    พิมพ์("")
    พิมพ์("📖 คำสั่งที่มี:")
    พิมพ์("  - ไป [สถานที่] - เดินทางไปยังสถานที่")
    พิมพ์("  - ดู / มอง - ดูรอบๆ")
    พิมพ์("  - เก็บ [ของ] - เก็บเครื่องดนตรีหรือโน้ต")
    พิมพ์("  - เรียน [บทเรียน] - เรียนบทเรียนภาษาไทย")
    พิมพ์("  - สถานะ / check - ดูสถานะของคุณ")
    พิมพ์("  - พบราชา - ไปพบพระราชา")
    พิมพ์("  - พบราชินี - ไปพบพระราชินี")
    พิมพ์("  - ช่วย / help - แสดงคำสั่งนี้")
    พิมพ์("  - ออก / quit - ออกจากเกม")
    พิมพ์("")
    คืน
  }
  
  // Collect items
  ถ้า คำสั่ง.เริ่มต้น("เก็บ") {
    รับ ชื่อของ = คำสั่ง.หลังจาก("เก็บ").ตัด()
    
    ถ้า ชื่อของ == "ระนาด" หรือ ชื่อของ == "ranad" {
