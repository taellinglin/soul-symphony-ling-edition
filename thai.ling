  // Meet the King
  ถ้า คำสั่ง == "พบราชา" {
    ถ้า สถานะ_ผู้เล่น.มี_ระนาด และ สถานะ_ผู้เล่น.มี_โน้ตโด และ สถานะ_ผู้เล่น.มี_โน้ตเร {
      ถ้า สถานะ_ผู้เล่น.พบ_ราชา == เท็จ {
        พิมพ์("")
        พิมพ์("👑 คุณพบพระราชา!")
        พิมพ์("พระราชาตรัสว่า: 'เจ้าได้พบระนาดและโน้ตโดและเร ข้าประทับใจในความรู้ของเจ้า'")
        พิมพ์("พระราชาตรัสว่า: 'จงไปพบราชินีที่ระเบียงแห่งความทรงจำ'")
        สถานะ_ผู้เล่น.พบ_ราชา = จริง
        สถานะ_ผู้เล่น.คะแนน = สถานะ_ผู้เล่น.คะแนน + 30
        พิมพ์("👑 +30 คะแนน!")
      } มิฉะนั้น {
        พิมพ์("👑 คุณได้พบพระราชาแล้ว ท่านบอกให้ไปพบราชินี")
      }
    } มิฉะนั้น {
      พิมพ์("👑 พระราชาจะไม่พบคุณจนกว่าคุณจะมีระนาดและโน้ตโดและโน้ตเร")
      พิมพ์("💡 ต้องมี: ระนาด, โน้ตโด, โน้ตเร")
    }
    คืน
  }
  
  // Meet the Queen
  ถ้า คำสั่ง == "พบราชินี" {
    ถ้า สถานะ_ผู้เล่น.มี_ซอ และ สถานะ_ผู้เล่น.มี_โน้ตฟา และ สถานะ_ผู้เล่น.มี_โน้ตซอล {
      ถ้า สถานะ_ผู้เล่น.พบ_ราชินี == เท็จ {
        พิมพ์("")
        พิมพ์("👸 คุณพบพระราชินี!")
        พิมพ์("พระราชินีตรัสว่า: 'เจ้าได้พบซอและโน้ตฟาและโน้ตซอล ข้าประทับใจในความเข้าใจของเจ้า'")
        พิมพ์("พระราชินีตรัสว่า: 'จงไปยังเวทีแห่งการแสดงเพื่อกู้ซิมโฟนีกลับคืนมา'")
        สถานะ_ผู้เล่น.พบ_ราชินี = จริง
        สถานะ_ผู้เล่น.คะแนน = สถานะ_ผู้เล่น.คะแนน + 30
        พิมพ์("👸 +30 คะแนน!")
      } มิฉะนั้น {
        พิมพ์("👸 คุณได้พบพระราชินีแล้ว ท่านบอกให้ไปยังเวที")
      }
    } มิฉะนั้น {
      พิมพ์("👸 พระราชินีจะไม่พบคุณจนกว่าคุณจะมีซอและโน้ตฟาและโน้ตซอล")
      พิมพ์("💡 ต้องมี: ซอ, โน้ตฟา, โน้ตซอล")
    }
    คืน
  }
  
  // Win condition - go to stage with everything
  ถ้า คำสั่ง == "กู้ซิมโฟนี" หรือ คำสั่ง == "ซิมโฟนี" {
    ถ้า สถานะ_ผู้เล่น.ตำแหน่ง_ปัจจุบัน == "เวที" {
      ถ้า สถานะ_ผู้เล่น.มี_ระนาด และ สถานะ_ผู้เล่น.มี_ขิม และ สถานะ_ผู้เล่น.มี_ซอ {
        ถ้า สถานะ_ผู้เล่น.มี_โน้ตโด และ สถานะ_ผู้เล่น.มี_โน้ตเร และ สถานะ_ผู้เล่น.มี_โน้ตมี และ สถานะ_ผู้เล่น.มี_โน้ตฟา และ สถานะ_ผู้เล่น.มี_โน้ตซอล {
          ถ้า สถานะ_ผู้เล่น.พบ_ราชา และ สถานะ_ผู้เล่น.พบ_ราชินี {
            พิมพ์("")
            พิมพ์("🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉")
            พิมพ์("🏆 คุณได้กู้ซิมโฟนีแห่งวิญญาณกลับคืนมาแล้ว! 🏆")
            พิมพ์("🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉🎉")
            พิมพ์("")
            พิมพ์("คุณได้เรียนรู้:")
            พิมพ์("  - วรรณยุกต์ทั้ง 5 (Do Re Mi Fa Sol)")
            พิมพ์("  - อักษรทั้ง 3 ชั้น (สูง กลาง ต่ำ)")
            พิมพ์("  - คำเป็นและคำตาย")
            พิมพ์("  - โครงสร้างประโยค SVO")
            พิมพ์("  - คำพ้องเสียง")
            พิมพ์("  - คำราชาศัพท์")
            พิมพ์("")
            พิมพ์("🎵 ซิมโฟนีบรรเลงอีกครั้ง...")
            พิมพ์("วิญญาณของภาษาไทยกลับมามีชีวิตอีกครั้ง!")
            พิมพ์("")
            พิมพ์("คะแนนรวม: " + สถานะ_ผู้เล่น.คะแนน + " คะแนน")
            พิมพ์("เครื่องดนตรี: " + สถานะ_ผู้เล่น.เครื่องดนตรี_ที่พบ.เข้าร่วม(", "))
            พิมพ์("โน้ต: " + สถานะ_ผู้เล่น.โน้ต_ที่พบ.เข้าร่วม(", "))
            พิมพ์("")
            พิมพ์("ขอบคุณที่เล่น! ขอให้ภาษาไทยอยู่ในใจคุณตลอดไป 🙏")
            คืน "win"
          } มิฉะนั้น {
            พิมพ์("❌ คุณยังไม่ได้พบราชาและราชินี! ไปพบพวกเขาก่อน")
          }
        } มิฉะนั้น {
          พิมพ์("❌ คุณยังไม่มีโน้ตครบทั้ง 5 ตัว!")
          พิมพ์("💡 ต้องมี: โด, เร, มี, ฟา, ซอล")
        }
      } มิฉะนั้น {
        พิมพ์("❌ คุณยังไม่มีเครื่องดนตรีครบทั้ง 3 ชิ้น!")
        พิมพ์("💡 ต้องมี: ระนาด, ขิม, ซอ")
      }
    } มิฉะนั้น {
      พิมพ์("❌ คุณต้องอยู่ที่เวทีแห่งการแสดงเพื่อกู้ซิมโฟนี")
      พิมพ์("💡 ไปที่ 'เวที'")
    }
    คืน
  }
  
  // Quit
  ถ้า คำสั่ง == "ออก" หรือ คำสั่ง == "quit" {
    พิมพ์("👋 ขอบคุณที่เล่น! วิญญาณซิมโฟนีรอคุณอยู่เสมอ")
    คืน "quit"
  }
  
  พิมพ์("❌ ไม่รู้จักคำสั่ง '" + คำสั่ง + "' พิมพ์ 'ช่วย' เพื่อดูคำสั่ง")
  คืน
}

// === MAIN GAME LOOP ===

ปฏิบัติ {
  พิมพ์("")
  พิมพ์("╔══════════════════════════════════════════════════╗")
  พิมพ์("║     วิญญาณซิมโฟนี - THE SOUL SYMPHONY         ║")
  พิมพ์("║     A Thai Linguistic Text Adventure            ║")
  พิมพ์("╚══════════════════════════════════════════════════╝")
  พิมพ์("")
  พิมพ์("📖 เรื่องราว:")
  พิมพ์("   ราชาและราชินีแห่งอาณาจักรภาษาไทยเคยครองราชย์ร่วมกัน")
  พิมพ์("   แต่แล้วซิมโฟนีแห่งวิญญาณก็สลายไป")
  พิมพ์("   เครื่องดนตรีทั้งสามและโน้ตทั้งห้าสาบสูญ")
  พิมพ์("   คุณคือนักดนตรีผู้ถูกเลือกให้กู้ซิมโฟนีกลับคืนมา!")
  พิมพ์("")
  พิมพ์("🎯 เป้าหมาย:")
  พิมพ์("   1. ค้นหาเครื่องดนตรี 3 ชิ้น: ระนาด, ขิม, ซอ")
  พิมพ์("   2. ค้นหาโน้ต 5 ตัว: โด, เร, มี, ฟา, ซอล")
  พิมพ์("   3. พบพระราชาและพระราชินี")
  พิมพ์("   4. ไปที่เวทีแห่งการแสดงและกู้ซิมโฟนี")
  พิมพ์("")
  
  รับ ชื่อผู้เล่น
  พิมพ์("👤 กรุณาใส่ชื่อของคุณ: ")
  รอ
  ชื่อผู้เล่น = อ่าน()
  สถานะ_ผู้เล่น.ชื่อ = ชื่อผู้เล่น
  
  พิมพ์("")
  พิมพ์("สวัสดี " + ชื่อผู้เล่น + "! การผจญภัยของคุณเริ่มต้นแล้ว!")
  พิมพ์("พิมพ์ 'ช่วย' เพื่อดูคำสั่งต่างๆ")
  พิมพ์("")
  
  กำหนด กำลังเล่น = จริง
  กำหนด ผลลัพธ์ = ""
  
  แสดง_ตำแหน่ง()
  
  ขณะ กำลังเล่น {
    พิมพ์("💬 " + ชื่อผู้เล่น + "> ")
    รับ คำสั่ง
    คำสั่ง = อ่าน().ตัด().ลด()
    
    ถ้า คำสั่ง == "" {
      ดำเนินการต่อ
    }
    
    ผลลัพธ์ = จัดการ_คำสั่ง(คำสั่ง)
    
    ถ้า ผลลัพธ์ == "quit" {
      กำลังเล่น = เท็จ
    }
    
    ถ้า ผลลัพธ์ == "win" {
      กำลังเล่น = เท็จ
    }
    
    ถ้า กำลังเล่น และ ผลลัพธ์ != "quit" และ ผลลัพธ์ != "win" {
      // ตรวจสอบเงื่อนไขการชนะอัตโนมัติทุกครั้ง
      ถ้า สถานะ_ผู้เล่น.มี_ระนาด และ สถานะ_ผู้เล่น.มี_ขิม และ สถานะ_ผู้เล่น.มี_ซอ {
        ถ้า สถานะ_ผู้เล่น.มี_โน้ตโด และ สถานะ_ผู้เล่น.มี_โน้ตเร และ สถานะ_ผู้เล่น.มี_โน้ตมี และ สถานะ_ผู้เล่น.มี_โน้ตฟา และ สถานะ_ผู้เล่น.มี_โน้ตซอล {
          ถ้า สถานะ_ผู้เล่น.พบ_ราชา และ สถานะ_ผู้เล่น.พบ_ราชินี {
            ถ้า สถานะ_ผู้เล่น.ตำแหน่ง_ปัจจุบัน == "เวที" {
              พิมพ์("")
              พิมพ์("🎉 ทุกอย่างพร้อมแล้ว! พิมพ์ 'กู้ซิมโฟนี' เพื่อจบเกม!")
            } มิฉะนั้น {
              พิมพ์("")
              พิมพ์("🎉 คุณมีทุกอย่างแล้ว! ไปที่เวทีแห่งการแสดงเพื่อกู้ซิมโฟนี!")
              พิมพ์("💡 พิมพ์ 'ไป เวที' เพื่อไปยังเวที")
            }
          }
        }
      }
    }
  }
  
  พิมพ์("")
  พิมพ์("╔══════════════════════════════════════════════════╗")
  พิมพ์("║          ขอบคุณที่เล่น! ขอบคุณ!              ║")
  พิมพ์("║      ภาษาไทยคือซิมโฟนีแห่งวิญญาณ            ║")
  พิมพ์("╚══════════════════════════════════════════════════╝")
}

