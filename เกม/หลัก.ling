        # ใช้ปกติของหน้าที่ใกล้ที่สุดสำหรับแรงโน้มถ่วง
        ผูก gx = list_get(face_normals_x, closest_face)
        ผูก gy = list_get(face_normals_y, closest_face)
        ผูก gz = list_get(face_normals_z, closest_face)
        ผูก gd = รากที่สอง(gx*gx + gy*gy + gz*gz)

        # ทำให้เป็นปกติและใช้เป็นทิศทางแรงโน้มถ่วง
        ถ้า gd > 0.001 {
            ผูก gx = gx / gd
            ผูก gy = gy / gd
            ผูก gz = gz / gd
            ผูก ลูกบอล_vx = ลูกบอล_vx - gx * แรงโน้มถ่วง * เวลา
            ผูก ลูกบอล_vy = ลูกบอล_vy - gy * แรงโน้มถ่วง * เวลา
            ผูก ลูกบอล_vz = ลูกบอล_vz - gz * แรงโน้มถ่วง * เวลา
        }

        ผูก ลูกบอล_px = ลูกบอล_px + ลูกบอล_vx * เวลา
        ผูก ลูกบอล_py = ลูกบอล_py + ลูกบอล_vy * เวลา
        ผูก ลูกบอล_pz = ลูกบอล_pz + ลูกบอล_vz * เวลา

        # ── การชนกับทรงสิบสองหน้า (ตรวจสอบทุกหน้า) ──────────────────────
        # ลูกบอลอยู่ภายในและควรเด้งออกจากหน้าทั้ง 12 หน้า
        ผูก scaled_radius = 50.0
        ผูก อยู่บนพื้น = 0

        # Collision check for all 12 faces - check face 0
        ผูก cfx = list_get(face_normals_x, 0)
        ผูก cfy = list_get(face_normals_y, 0)
        ผูก cfz = list_get(face_normals_z, 0)
        ผูก cfd = รากที่สอง(cfx*cfx + cfy*cfy + cfz*cfz)
        ถ้า cfd > 0.001 {
            ผูก cfx = cfx / cfd
            ผูก cfy = cfy / cfd
            ผูก cfz = cfz / cfd
        }
        ผูก face_dist = ลูกบอล_px * cfx + ลูกบอล_py * cfy + ลูกบอล_pz * cfz
        ถ้า face_dist > (scaled_radius - รัศมีลูกบอล - 2.0) {
            ถ้า face_dist < (scaled_radius + รัศมีลูกบอล) {
                ผูก push_amount = (scaled_radius - รัศมีลูกบอล) - face_dist
                ผูก ลูกบอล_px = ลูกบอล_px + cfx * push_amount
                ผูก ลูกบอล_py = ลูกบอล_py + cfy * push_amount
                ผูก ลูกบอล_pz = ลูกบอล_pz + cfz * push_amount

                ผูก vel_dot_normal = ลูกบอล_vx * cfx + ลูกบอล_vy * cfy + ลูกบอล_vz * cfz
                ถ้า vel_dot_normal < 0 {
                    ผูก bounceImpulse = vel_dot_normal * (1.0 + การเด้ง)
                    ผูก ลูกบอล_vx = ลูกบอล_vx - cfx * bounceImpulse
                    ผูก ลูกบอล_vy = ลูกบอล_vy - cfy * bounceImpulse
                    ผูก ลูกบอล_vz = ลูกบอล_vz - cfz * bounceImpulse
                }
                ผูก อยู่บนพื้น = 1
            }
        }

