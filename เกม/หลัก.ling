                    ผูก ลูกบอล_px = ลูกบอล_px + cfx * push_amount
                    ผูก ลูกบอล_py = ลูกบอล_py + cfy * push_amount
                    ผูก ลูกบอล_pz = ลูกบอล_pz + cfz * push_amount

                    ผูก vel_dot_normal = ลูกบอล_vx * cfx + ลูกบอล_vy * cfy + ลูกบอล_vz * cfz
                    ถ้า vel_dot_normal < 0 {
                        ผูก bounceImpulse = vel_dot_normal * (1.0 + การเด้ง)
                        ผูก ลูกบอล_vx = ลูกบอล_vx - cfx * bounceImpulse
                        ผูก ลูกบอล_vy = ลูกบอล_vy - cfy * bounceImpulse
                        ผูก ลูกบอล_vz = ลูกบอล_vz - cfz * bounceImpulse
                    }
                    ผูก อยู่บนพื้น = 1
                }
            }
            ผูก fi = 9
        }

        ผูก fi = 9
        ขณะที่ fi == 9 {
            ผูก cfx = list_get(face_normals_x, 9)
            ผูก cfy = list_get(face_normals_y, 9)
            ผูก cfz = list_get(face_normals_z, 9)
            ผูก cfd = รากที่สอง(cfx*cfx + cfy*cfy + cfz*cfz)
            ถ้า cfd > 0.001 {
                ผูก cfx = cfx / cfd
                ผูก cfy = cfy / cfd
                ผูก cfz = cfz / cfd
            }
            ผูก face_dist = ลูกบอล_px * cfx + ลูกบอล_py * cfy + ลูกบอล_pz * cfz
            ถ้า face_dist > (scaled_radius - รัศมีลูกบอล - 2.0) {
                ถ้า face_dist < (scaled_radius + รัศมีลูกบอล) {
                    ผูก push_amount = (scaled_radius - รัศมีลูกบอล) - face_dist
                    ผูก ลูกบอล_px = ลูกบอล_px + cfx * push_amount
                    ผูก ลูกบอล_py = ลูกบอล_py + cfy * push_amount
                    ผูก ลูกบอล_pz = ลูกบอล_pz + cfz * push_amount

                    ผูก vel_dot_normal = ลูกบอล_vx * cfx + ลูกบอล_vy * cfy + ลูกบอล_vz * cfz
                    ถ้า vel_dot_normal < 0 {
                        ผูก bounceImpulse = vel_dot_normal * (1.0 + การเด้ง)
                        ผูก ลูกบอล_vx = ลูกบอล_vx - cfx * bounceImpulse
                        ผูก ลูกบอล_vy = ลูกบอล_vy - cfy * bounceImpulse
                        ผูก ลูกบอล_vz = ลูกบอล_vz - cfz * bounceImpulse
                    }
                    ผูก อยู่บนพื้น = 1
                }
            }
            ผูก fi = 10
        }

        ผูก fi = 10
        ขณะที่ fi == 10 {
            ผูก cfx = list_get(face_normals_x, 10)
            ผูก cfy = list_get(face_normals_y, 10)
            ผูก cfz = list_get(face_normals_z, 10)
            ผูก cfd = รากที่สอง(cfx*cfx + cfy*cfy + cfz*cfz)
            ถ้า cfd > 0.001 {
                ผูก cfx = cfx / cfd
                ผูก cfy = cfy / cfd
                ผูก cfz = cfz / cfd
            }
            ผูก face_dist = ลูกบอล_px * cfx + ลูกบอล_py * cfy + ลูกบอล_pz * cfz
            ถ้า face_dist > (scaled_radius - รัศมีลูกบอล - 2.0) {
                ถ้า face_dist < (scaled_radius + รัศมีลูกบอล) {
                    ผูก push_amount = (scaled_radius - รัศมีลูกบอล) - face_dist
                    ผูก ลูกบอล_px = ลูกบอล_px + cfx * push_amount
                    ผูก ลูกบอล_py = ลูกบอล_py + cfy * push_amount
                    ผูก ลูกบอล_pz = ลูกบอล_pz + cfz * push_amount

                    ผูก vel_dot_normal = ลูกบอล_vx * cfx + ลูกบอล_vy * cfy + ลูกบอล_vz * cfz
                    ถ้า vel_dot_normal < 0 {
                        ผูก bounceImpulse = vel_dot_normal * (1.0 + การเด้ง)
                        ผูก ลูกบอล_vx = ลูกบอล_vx - cfx * bounceImpulse
                        ผูก ลูกบอล_vy = ลูกบอล_vy - cfy * bounceImpulse
                        ผูก ลูกบอล_vz = ลูกบอล_vz - cfz * bounceImpulse
                    }
                    ผูก อยู่บนพื้น = 1
                }
            }
            ผูก fi = 11
        }

        ผูก fi = 11
        ขณะที่ fi == 11 {
            ผูก cfx = list_get(face_normals_x, 11)
            ผูก cfy = list_get(face_normals_y, 11)
            ผูก cfz = list_get(face_normals_z, 11)
            ผูก cfd = รากที่สอง(cfx*cfx + cfy*cfy + cfz*cfz)
            ถ้า cfd > 0.001 {
                ผูก cfx = cfx / cfd
                ผูก cfy = cfy / cfd
                ผูก cfz = cfz / cfd
            }
            ผูก face_dist = ลูกบอล_px * cfx + ลูกบอล_py * cfy + ลูกบอล_pz * cfz
            ถ้า face_dist > (scaled_radius - รัศมีลูกบอล - 2.0) {
                ถ้า face_dist < (scaled_radius + รัศมีลูกบอล) {
                    ผูก push_amount = (scaled_radius - รัศมีลูกบอล) - face_dist
                    ผูก ลูกบอล_px = ลูกบอล_px + cfx * push_amount
                    ผูก ลูกบอล_py = ลูกบอล_py + cfy * push_amount
                    ผูก ลูกบอล_pz = ลูกบอล_pz + cfz * push_amount

                    ผูก vel_dot_normal = ลูกบอล_vx * cfx + ลูกบอล_vy * cfy + ลูกบอล_vz * cfz
                    ถ้า vel_dot_normal < 0 {
                        ผูก bounceImpulse = vel_dot_normal * (1.0 + การเด้ง)
                        ผูก ลูกบอล_vx = ลูกบอล_vx - cfx * bounceImpulse
                        ผูก ลูกบอล_vy = ลูกบอล_vy - cfy * bounceImpulse
                        ผูก ลูกบอล_vz = ลูกบอล_vz - cfz * bounceImpulse
                    }
                    ผูก อยู่บนพื้น = 1
                }
            }
            ผูก fi = 12
        }

        # ── แรงเสียดทาน (แนวนอนเมื่ออยู่บนพื้นเท่านั้น) ──────────────────
        ถ้า อยู่บนพื้น == 1 {
            ผูก ลูกบอล_vx = ลูกบอล_vx * แรงเสียดทาน
            ผูก ลูกบอล_vz = ลูกบอล_vz * แรงเสียดทาน
        }

        # ── อัพเดตหน้าที่ใกล้ที่สุด (สำหรับแรงโน้มถ่วง + กล้อง) ────────────
        # ตรวจสอบระยะทางถึงทุกหน้า และใช้หน้าที่ใกล้ที่สุด
        ผูก new_closest_face = 0
        ผูก new_closest_dist = 1000.0

        # Check face 0
        ผูก check_fx = list_get(face_normals_x, 0)
        ผูก check_fy = list_get(face_normals_y, 0)
        ผูก check_fz = list_get(face_normals_z, 0)
        ผูก check_fd = รากที่สอง(check_fx*check_fx + check_fy*check_fy + check_fz*check_fz)
        ถ้า check_fd > 0.001 {
            ผูก check_fx = check_fx / check_fd
            ผูก check_fy = check_fy / check_fd
            ผูก check_fz = check_fz / check_fd
        }
        ผูก check_dist = ลูกบอล_px * check_fx + ลูกบอล_py * check_fy + ลูกบอล_pz * check_fz
        ถ้า check_dist < new_closest_dist {
            ผูก new_closest_dist = check_dist
            ผูก new_closest_face = 0
        }

        ผูก closest_face = new_closest_face

        # ── E: สนทนาจิตใจ ──────────────────────────────────────────────
        ถ้า กดปุ่ม("e") {
            ผูก ดัชนีสนทนา = ดัชนีสนทนา + 1
            ถ้า ดัชนีสนทนา >= ความยาว(สนทนา) { ผูก ดัชนีสนทนา = 0 }
            พิมพ์("  จิตใจ: " + list_get(สนทนา, ดัชนีสนทนา))
            ผูก คะแนน = คะแนน + 1
        }

        # ── N: เปลี่ยนแดน + เสียง ──────────────────────────────────────
        ถ้า กดปุ่ม("n") {
            ผูก แดน = แดน + 1
            ถ้า แดน > 3 { ผูก แดน = 0 }
            ถ้า แดน == 0 { พิมพ์("  [ แดน ๑ — ความว่างเปล่า ]");            ตั้งเสียงความว่าง()      }
            ถ้า แดน == 1 { พิมพ์("  [ แดน ๒ — มหาสมุทรจิต ]");        ตั้งเสียงมหาสมุทร()     }
            ถ้า แดน == 2 { พิมพ์("  [ แดน ๓ — อาณาจักรคริสตัล ]");      ตั้งเสียงคริสตัล()   }
            ถ้า แดน == 3 { พิมพ์("  [ แดน ๔ — สรณะแห่งดวงวิญญาณ ]");      ตั้งเสียงสรณะ() }
        }

        # ── กล้องลอยตัวตามบอล (bobber mode): ติดตามบอลโดยใช้ปกติของหน้า ────
        # ใช้ปกติของหน้าที่ใกล้ที่สุดเป็น "ขึ้น" ท้องถิ่น
        ผูก up_x = list_get(face_normals_x, closest_face)
        ผูก up_y = list_get(face_normals_y, closest_face)
        ผูก up_z = list_get(face_normals_z, closest_face)
        ผูก up_d = รากที่สอง(up_x*up_x + up_y*up_y + up_z*up_z)
        ถ้า up_d > 0.001 {
            ผูก up_x = up_x / up_d
            ผูก up_y = up_y / up_d
            ผูก up_z = up_z / up_d
        }

        # สร้าง right vector ที่ตั้งฉากกับ up
        # ใช้ cross product: right = (0,1,0) × up (if not parallel)
        ผูก right_x = 0.0 - up_z
        ผูก right_y = 0.0
        ผูก right_z = up_x
        
        ผูก right_d = รากที่สอง(right_x*right_x + right_y*right_y + right_z*right_z)
        ถ้า right_d < 0.1 {
            # ถ้า up ~ (0,1,0) ให้ใช้ (1,0,0) × up instead
            ผูก right_x = 0.0
            ผูก right_y = up_z
            ผูก right_z = 0.0 - up_y
            ผูก right_d = รากที่สอง(right_x*right_x + right_y*right_y + right_z*right_z)
        }

        ถ้า right_d > 0.001 {
            ผูก right_x = right_x / right_d
            ผูก right_y = right_y / right_d
            ผูก right_z = right_z / right_d
        }

        # forward = up × right
        ผูก fwd_x = up_y * right_z - up_z * right_y
        ผูก fwd_y = up_z * right_x - up_x * right_z
        ผูก fwd_z = up_x * right_y - up_y * right_x

        # ตำแหน่งกล้อง: ลูกบอล + (ขึ้น * 6.0) + (ด้านข้าง * 8.0 * orbit)
        ผูก cam_up_dist = 6.0
        ผูก cam_orbit = 8.0
        
        ผูก orbit_cos = โคไซน์(มุมกล้อง)
        ผูก orbit_sin = ไซน์(มุมกล้อง)
        
        ผูก cpx = ลูกบอล_px + up_x * cam_up_dist + right_x * cam_orbit * orbit_cos + fwd_x * cam_orbit * orbit_sin
        ผูก cpy = ลูกบอล_py + up_y * cam_up_dist + right_y * cam_orbit * orbit_cos + fwd_y * cam_orbit * orbit_sin
        ผูก cpz = ลูกบอล_pz + up_z * cam_up_dist + right_z * cam_orbit * orbit_cos + fwd_z * cam_orbit * orbit_sin

        # ทิศทางการมองชี้ลงไปยังลูกบอล
        ผูก ldx = ลูกบอล_px - cpx
        ผูก ldy = ลูกบอล_py - cpy
        ผูก ldz = ลูกบอล_pz - cpz
        ผูก ll  = รากที่สอง(ldx*ldx + ldy*ldy + ldz*ldz)
        ถ้า ll < 0.001 { ผูก ll = 0.001 }

        ผูก ry  = atan2(ldx / ll, ldz / ll)
        ผูก rx  = asin(จำกัด(ldy / ll, 0.0-0.98, 0.98))
        ผูก cry = โคไซน์(ry); ผูก sry = ไซน์(ry)
        ผูก crx = โคไซน์(rx); ผูก srx = ไซน์(rx)
        ตั้งกล้อง(cry, sry, crx, srx)
        ตั้งตำแหน่งกล้อง(cpx, cpy, cpz)
        ตั้งระยะห่าง(ระยะZ)

        # ── เสียง 4 มิติ: ผู้ฟังและโทนไฮเพอร์โบลิก ───────────────────
        ผู้ฟัง(cry, sry, crx, srx)
        ผูก ไฮเพอร์_d = รากที่สอง(ลูกบอล_px*ลูกบอล_px + ลูกบอล_py*ลูกบอล_py + ลูกบอล_pz*ลูกบอล_pz) / รัศมีทรงกลม
        เสียงโทน(6,  ลูกบอล_px, ลูกบอล_py, ลูกบอล_pz,
                   1.0 + ไฮเพอร์_d * 0.9,
                   55.0 + ไฮเพอร์_d * 38.0,  0.05,  0.35,  0.022)

        # ── ล้าง ────────────────────────────────────────────────────────
        ถ้า แดน == 0 { เติม( 1,  0,  6) }
        ถ้า แดน == 1 { เติม( 0,  2, 18) }
        ถ้า แดน == 2 { เติม( 5,  1, 14) }
        ถ้า แดน == 3 { เติม( 7,  3,  0) }

        # ── แสง ─────────────────────────────────────────────────────────
        ล้างแสง()
        ตั้งแสงรอบข้าง(0.30)
        เพิ่มแสง(ไซน์(กรอบ*0.010)*12.0 + ลูกบอล_px,  ลูกบอล_py + 6.5,
                  โคไซน์(กรอบ*0.010)*6.0  + ลูกบอล_pz,  1.0,0.88,0.60, 3.5,24.0)
        เพิ่มแสง(ลูกบอล_px, ลูกบอล_py + 0.4, ลูกบอล_pz,   0.5,0.18,1.0, 1.8, 9.0)
        เพิ่มแสง(ไซน์(กรอบ*0.007+1.5)*9.0 + ลูกบอล_px,  ลูกบอล_py + 2.0,
                  โคไซน์(กรอบ*0.007)*8.0 + ลูกบอล_pz,   1.0,0.20,0.90, 1.2,14.0)

        # ── วาดฉาก ──────────────────────────────────────────────────────
        # สิบสองหน้าไฮเพอร์โบลิก-พาราโบลิก (โครงลวดสีรุ้ง + หน้าโปร่งแสง)
        วาดสิบสองหน้าไฮเพอร์โบลิก(ขนาดลูกบาศก์, กรอบ)

        # ต้นไม้และหญ้า
        ผูก ti = 0
        ขณะที่ ti < 6 {
            ผูก tx = ไซน์(tau * ti / 6.0 + กรอบ * 0.001) * 40.0
            ผูก tz = โคไซน์(tau * ti / 6.0 + กรอบ * 0.001) * 40.0
            วาดต้นไม้(tx, 0.0-ขนาดลูกบาศก์*0.5 + 3.0, tz, 5.0, กรอบ)
            วาดหญ้า(tx + 8.0, 0.0-ขนาดลูกบาศก์*0.5 + 0.5, tz + 8.0, กรอบ)
            ผูก ti = ti + 1
        }

        # ลูกบอล
        วาดลูกบอล(ลูกบอล_px, ลูกบอล_py, ลูกบอล_pz,  รัศมีลูกบอล,  10, 24,  กรอบ)
        วาดโอรา(ลูกบอล_px, ลูกบอล_py, ลูกบอล_pz, กรอบ)
        วาดลายแดน(แดน, ลูกบอล_px, ลูกบอล_py, ลูกบอล_pz, กรอบ)

        แสดงผล()
        ผูก กรอบ = กรอบ + 1
    }

    # ── ออก ─────────────────────────────────────────────────────────────────
    พิมพ์("")
    พิมพ์("══════════════════════════════════════════════════════════════")
    พิมพ์("  Soul Symphony Ling  |  เซ็ชั่นเสร็จสิ้น")
    พิมพ์("  จิตใจที่สนทนา: " + to_str(คะแนน))
    พิมพ์("  สิ่งประดิษฐ์ยังคงเล่นต่อไป")
    พิมพ์("══════════════════════════════════════════════════════════════")
}
